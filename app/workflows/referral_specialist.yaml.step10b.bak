family: referral_specialist

trigger_hints:
  - ուղեգիր
  - մասնագետ
  - որտեղ գնամ
  - referral
  - specialist

required_fields:
  - need_type

field_questions:
  need_type: "Գրե՛ք՝ խոսքը նեղ մասնագետի, հետազոտության, թե ընդհանուր բուժօգնության մասին է։"

field_priority:
  - need_type
  - specialist_or_service
  - has_referral_context

branches:
  - id: specialist_route
    when:
      need_type: specialist
    answer: "Եթե խոսքը նեղ մասնագետի դիմելու մասին է, առաջին քայլը սովորաբար պոլիկլինիկա կամ ընտանեկան բժիշկն է՝ հասկանալու համար, թե ուղեգիր պահանջվո՞ւմ է, թե ոչ։"
    answer_with_detail: "Եթե խոսքը {specialist_or_service}-ի դիմելու մասին է, առաջին քայլը սովորաբար պոլիկլինիկա կամ ընտանեկան բժիշկն է՝ հասկանալու համար, թե ուղեգիր պահանջվո՞ւմ է, թե ոչ։"
    next_step: "Դիմեք ձեր պոլիկլինիկա կամ ընտանեկան բժշկին՝ տվյալ մասնագետի դիմելու ճիշտ ուղին ճշտելու համար։"
    next_step_with_detail: "Դիմեք ձեր պոլիկլինիկա կամ ընտանեկան բժշկին՝ {specialist_or_service}-ի դիմելու ճիշտ ուղին ճշտելու համար։"

  - id: diagnostic_route
    when:
      need_type: diagnostic
    answer: "Եթե խոսքը հետազոտության մասին է, հաջորդ քայլը կախված է հետազոտության տեսակից և նրանից՝ դրա համար ուղեգիր պահանջվո՞ւմ է, թե ոչ։"
    answer_with_detail: "Եթե խոսքը {specialist_or_service}-ի մասին է, հաջորդ քայլը կախված է նրանից՝ այդ հետազոտության համար ուղեգիր պահանջվո՞ւմ է, թե ոչ։"
    next_step: "Նախ ճշտեք հետազոտության տեսակը, հետո դիմեք ձեր բժշկին կամ պոլիկլինիկա՝ հասկանալու համար՝ ուղեգիր պետք է, թե ոչ։"
    next_step_with_detail: "Նախ ճշտեք՝ {specialist_or_service}-ի համար ուղեգիր պահանջվո՞ւմ է, հետո դիմեք ձեր բժշկին կամ պոլիկլինիկա՝ հաջորդ քայլը հասկանալու համար։"

  - id: general_route
    when:
      need_type: general
    answer: "Եթե հարցը ընդհանուր բուժօգնության մասին է, սովորական առաջին կետը պոլիկլինիկան կամ ընտանեկան բժիշկն է։"
    next_step: "Դիմեք ձեր պոլիկլինիկա կամ ընտանեկան բժշկին՝ հետագա ուղղորդման համար։"

source_preferences:
  - moh.am_referral_pages
  - curated_referral_rules
