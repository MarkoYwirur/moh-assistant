import json
from pathlib import Path

from app.controller_v2 import run_controller_v2

CASES_PATH = Path("app/data/regression/v2_regression_cases.json")
OUT_PATH = Path("app/data/regression/v2_regression_results.json")


def main():
    cases = json.loads(CASES_PATH.read_text(encoding="utf-8"))
    results = []

    for case in cases:
        result = run_controller_v2(case["message"], {})
        actual_behavior = "clarify" if result.get("action") == "clarify" else "answer"

        results.append({
            "id": case["id"],
            "family_expected": case["family"],
            "message": case["message"],
            "expected_behavior": case["expected_behavior"],
            "actual_behavior": actual_behavior,
            "matched_family": result.get("matched_family"),
            "action": result.get("action"),
            "answer": result.get("answer"),
            "follow_up_question": result.get("follow_up_question"),
            "next_step": result.get("next_step"),
            "behavior_match": actual_behavior == case["expected_behavior"],
            "family_match": result.get("matched_family") == case["family"],
        })

    OUT_PATH.write_text(json.dumps(results, ensure_ascii=False, indent=2), encoding="utf-8")
    print(f"WROTE {OUT_PATH}")
    print(f"TOTAL={len(results)}")
    print(f"BEHAVIOR_MATCHES={sum(1 for r in results if r['behavior_match'])}")
    print(f"FAMILY_MATCHES={sum(1 for r in results if r['family_match'])}")


if __name__ == "__main__":
    main()
